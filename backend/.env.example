# Copy this to .env and fill in your values
# NEVER commit .env to git

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Groq
GROQ_API_KEY=your-groq-api-key
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Celery / Redis
REDIS_URL=redis://localhost:6379/0

# GitHub OAuth (for private repo access)
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# App
APP_ENV=development
APP_SECRET_KEY=your-random-32-char-secret-replace-this
FRONTEND_URL=http://localhost:3000
# For production with multiple domains, use comma-separated origins:
# FRONTEND_URL=https://your-project.vercel.app,https://your-custom-domain.com

# Internal API auth (for n8n to call backend)
INTERNAL_API_KEY=your-random-internal-api-key

# Playwright
PLAYWRIGHT_HEADLESS=false
